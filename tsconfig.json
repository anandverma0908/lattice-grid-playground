{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@lattice-grid-lib/core": [
        "../lattice-grid/src/index.ts"
      ]
    }
  },
  "include": [
    "src",
    "../lattice-grid/src"
  ],
  "exclude": [
    "../lattice-grid/src/__tests__"
  ]
}
